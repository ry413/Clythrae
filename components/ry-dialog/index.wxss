.dialog-mask {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}

.dialog-box {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  min-width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx 30rpx;
  z-index: 1000;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
}

.dialog-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}

.cancel, .confirm {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 12rpx;
}

.cancel {
  background-color: #f2f2f2;
  color: #333;
}

.confirm {
  background-color: #0081ff;
  color: white;
}

