.title {
  font-size: large;
  font-weight: bold;
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin: 20rpx;
}

.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 1000;
}

.dialog-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  z-index: 1001;
  width: 600rpx;
}

.grid-item {
  background-color: #f2f2f2;
  border-radius: 12rpx;
  text-align: center;
  color: #333;
  font-weight: bold;
}

.grid-item.selected {
  background-color: cornflowerblue;
  color: #fff;
}

.input-row {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}


.dialog-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}

.cancel, .confirm {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 12rpx;
}

.cancel {
  background-color: #f2f2f2;
  color: #333;
}

.confirm {
  background-color: #0081ff;
  color: white;
}
