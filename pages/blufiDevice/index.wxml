<view class="page">
  <view class="weui-form">
    <view class="weui-form__control-area">
      <view class="weui-cells__group weui-cells__group_form">
        <view class="weui-cells__title">当前选择wifi: {{ssid}}</view>
        <view class="weui-cells weui-cells_form">
          <view class="weui-cell">
            <picker bindchange="bindPickerChange" value="{{selectedWifiIndex}}" range="{{wifiList}}">
              <view class="picker">
                Wi-Fi列表: {{wifiList[selectedWifiIndex]}}
              </view>
            </picker>
          </view>
          <view class="weui-cell">
            <view class="weui-cell__hd"><label class="weui-label">密码：</label></view>
            <view class="weui-cell__bd">
              <input class="weui-input" value="{{password}}" bindinput="bindPasswordInput" type="text"
                placeholder="在此输入Wi-Fi密码" />
            </view>
          </view>

          <!-- <view class="weui-cell">
            <view class="weui-cell__hd"><label class="weui-label">数据：</label></view>
            <view class="weui-cell__bd">
              <input class="weui-input" bindinput="bindCustomDataInput" type="text" placeholder="在此输入自定义数据" />
            </view>
          </view> -->
        </view>
      </view>
    </view>
    <!-- <view class="weui-form__tips-area">
      <label for="weuiAgree" class="weui-agree">
        <input id="weuiAgree" type="checkbox" class="weui-agree__checkbox" /><span
          class="weui-agree__text">{{connected?"蓝牙已连接":"蓝牙已断开"}}
        </span>
      </label>
    </view> -->

    <view class="weui-form__opr-area">
      <text>{{deviceInitOK}}/{{wifiInitOK}}</text>
      <button bindtap="OnClickStart" disabled="{{!deviceInitOK || !wifiInitOK }}"
        type="primary">{{deviceInitOK ? "开始配网" : "设备或网络初始化失败"}}</button>
    </view>
  </view>
</view>