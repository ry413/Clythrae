<t-navbar title="智能体" fixed="{{false}}" placeholder left-arrow t-class-title="nav-title" />
<view>
  <t-tabs defaultValue="{{0}}" t-class="custom-tabs" swipeable="{{false}}">
    <t-tab-panel label="角色配置" value="0">
      <view>
        <text class="title">助手昵称</text>
        <t-input placeholder="请输入助手昵称" bind:change="onAgentNameChange" value="{{agentForm.agentName}}" />
      </view>

      <view class="block">
        <text class="title">角色模板</text>
        <t-grid hover column="{{0}}" theme="card">
          <t-grid-item wx:for="{{roleTemplates}}" t-class-text="role-template-text" wx:key="id"
            text="{{item.agentName}}" data-template-id="{{item.id}}" bind:tap="selecteRoleTemplate" />
        </t-grid>
      </view>

      <view>
        <text class="title">角色设定</text>
        <t-textarea placeholder="请输入角色设定" maxlength="2000" indicator autosize="{{textareaAutosize}}"
          bind:change="onAgentPromptChange" value="{{agentForm.systemPrompt}}" />
      </view>

      <view>
        <text class="title">历史记忆</text>
        <t-textarea maxlength="2000" indicator autosize="{{textareaAutosize}}" bind:change="onAgentMemoryChange"
          value="{{memory}}" />
      </view>

      <view>
        <text class="title">模型配置</text>
        <t-cell class="mb-16" title="大语言模型" arrow hover note="{{displayNames.LLM}}" bind:click="onPickerOpen"
          data-key="llm" />
        <t-picker visible="{{llmPickerVisible}}" value="{{[agentForm.llmModelId]}}" data-key="llm" title="选择大模型"
          cancelBtn="取消" confirmBtn="确认" usingCustomNavbar bind:confirm="onPickerConfirm" bind:cancel="onPickerCancel">
          <t-picker-item options="{{modelOptions.LLM}}" />
        </t-picker>

        <t-cell class="mb-16" title="语音模型" arrow hover note="{{displayNames.TTS}} {{displayNames.VOICE}}"
          bind:click="onPickerOpen" data-key="tts" />
        <t-picker visible="{{ttsPickerVisible}}" value="{{selectedTTSAndVoiceValue}}" data-key="tts" title="选择模型"
          cancelBtn="取消" confirmBtn="确认" usingCustomNavbar bindchange="onPickerConfirm" bindpick="onVoiceColumnChange"
          bindcancel="onPickerCancel">
          <t-picker-item options="{{modelOptions.TTS}}" />
          <t-picker-item options="{{currVoiceOptions}}" />
        </t-picker>
      </view>

      <view class="full-width-button">
        <t-button theme="primary" size="large" loading="{{saving}}" disabled="{{saving}}" block bind:tap="saveAgent">
          {{saving ? '保存中' : '保存'}}
        </t-button>
      </view>
    </t-tab-panel>

    <t-tab-panel label="编辑功能" value="1">
      <t-cell wx:for="{{allFunctions}}" wx:key="id" title="{{item.name}}">
        <t-switch slot="note" value="{{checkedMap[item.id]}}" data-id="{{item.id}}" data-index="{{index}}" bind:change="onSwitchChange" />
      </t-cell>

      <view>
        <t-input label="MCP接入点地址" value="{{mcpAddress}}" disabled>
          <t-button slot="extra" theme="primary" size="extra-small" bind:tap="copyMcpAddress">点击复制</t-button>
        </t-input>
      </view>

      <view class="full-width-button">
        <t-button theme="primary" size="large" loading="{{saving}}" disabled="{{saving}}" block
          bind:tap="saveAgentFunctions">
          {{functionsSaving ? '保存中' : '保存功能'}}
        </t-button>
      </view>
    </t-tab-panel>

    <t-tab-panel label="设备配置" value="2">
      <!-- <view class="full-width-button">
        <t-button size="large" theme="danger" block bind:tap="deleteAgent">解绑设备并删除智能体</t-button>
      </view> -->
      <device-config />
    </t-tab-panel>

  </t-tabs>
</view>