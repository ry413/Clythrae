.page {
  padding: 24rpx;
}

.header {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.header-text {
  flex: 1;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  color: #111827;
}

.subtitle {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-top: 8rpx;
}

.status-text {
  text-align: center;
  color: #9ca3af;
  padding: 60rpx 0;
}

.wallpaper-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.wallpaper-item {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f3f4f6;
  height: 260rpx;
  border: 2rpx solid transparent;
}

.wallpaper-item.selected {
  border-color: #55a630;
}

.wallpaper-img {
  width: 100%;
  height: 100%;
}

.wallpaper-mask {
  position: absolute;
  inset: 0;
  background: rgba(85, 166, 48, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mask-text {
  color: #fff;
  font-weight: 700;
  font-size: 28rpx;
}

.delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-text {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.builtin-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
}

.builtin-text {
  color: #fff;
  font-size: 20rpx;
}

.footer {
  margin-top: 32rpx;
}

.cropper-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
}
